FINNHUB_API_KEY=your_finnhub_api_key
FINNHUB_WEBSOCKET_URL=wss://ws.finnhub.io

KAFKA_BROKER=kafka:9092
KAFKA_TOPIC=stock_trades
KAFKA_CLIENT_ID=stock-trade-producer
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION_FACTOR=1
KAFKA_RETRIES=10
KAFKA_LINGER_MS=100
KAFKA_FLUSH_TIMEOUT_SECONDS=15

STOCK_SYMBOLS=AAPL,MSFT,AMZN,GOOGL

LOG_LEVEL=INFO

SPARK_APP_NAME=stock-streaming-job
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_CHECKPOINT_ROOT=/opt/project/.checkpoints
SPARK_WATERMARK_DELAY=2 minutes
SPARK_SHUFFLE_PARTITIONS=4
SPARK_MAX_OFFSETS_PER_TRIGGER=5000

ICEBERG_CATALOG_NAME=stock_catalog
ICEBERG_NAMESPACE=stock
ICEBERG_WAREHOUSE=file:///data/warehouse

HIVE_METASTORE_URI=thrift://hive-metastore:9083

TRINO_HOST=trino
TRINO_PORT=8080
TRINO_CATALOG=iceberg
TRINO_SCHEMA=stock

WEBSOCKET_PING_INTERVAL_SECONDS=20
WEBSOCKET_PING_TIMEOUT_SECONDS=10
WEBSOCKET_RECONNECT_DELAY_SECONDS=5

AIRFLOW_UID=50000

SUPERSET_SECRET_KEY=change_me_for_local_dev
